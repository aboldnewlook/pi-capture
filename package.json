{
  "name": "pi-capture",
  "version": "0.2.0",
  "description": "Pi extension for capturing and triaging issues into Linear (or other backends) from the agent conversation",
  "author": "aboldnewlook",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aboldnewlook/pi-capture.git"
  },
  "homepage": "https://github.com/aboldnewlook/pi-capture#readme",
  "bugs": {
    "url": "https://github.com/aboldnewlook/pi-capture/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "linear",
    "issue-capture",
    "triage"
  ],
  "bin": {
    "pi-capture": "install.mjs"
  },
  "files": [
    "src/**/*.ts",
    "*.mjs",
    "skills/**/*",
    "pi-capture.schema.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "node --experimental-strip-types --test test/*.test.ts",
    "lint": "tsc --noEmit",
    "build": "tsc --noEmit"
  },
  "pi": {
    "extensions": [
      "./src/extension/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "pi-subagents": ">=0.4.0"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-agent-core": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    },
    "pi-subagents": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "typescript": "^5.5.0"
  }
}
